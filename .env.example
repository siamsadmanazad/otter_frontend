# TripOtter — Environment Variable Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017/tripotter"

# ── Authentication (NextAuth) ─────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
JWT_SECRET=""

# ── External Services ─────────────────────────────────────────────────────────
# Google Gemini AI (https://aistudio.google.com/app/apikey)
GOOGLE_GENAI_API_KEY=""

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=""

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Find these at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_TOKEN=""
NEXT_PUBLIC_SANITY_API_VERSION="2025-07-06"

# ── Service URLs ──────────────────────────────────────────────────────────────
# tripotter-pulse NestJS microservice (real-time WebSocket + notifications)
PULSE_BASE_URL="http://localhost:10000"
NEXT_PUBLIC_PULSE_BASE_URL="http://localhost:10000"

# This Next.js application
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# WebSocket server (same as pulse in most setups)
NEXT_PUBLIC_WS_BASE_URL="http://localhost:10000"
