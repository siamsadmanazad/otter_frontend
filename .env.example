# TripOtter — Environment Variable Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + keys: Supabase dashboard → Project Settings → API.
# (For local dev with the Supabase CLI, `supabase start` prints local URL + keys.)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SERVER ONLY. Bypasses Row-Level Security. Never prefix with NEXT_PUBLIC_,
# never ship to the client. Used only by lib/supabase/admin.ts inside app/api routes.
SUPABASE_SERVICE_ROLE_KEY=""

# ── AI & Email (server-side only) ─────────────────────────────────────────────
# Google Gemini AI (https://aistudio.google.com/app/apikey)
GOOGLE_GENAI_API_KEY=""

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
# Optional; defaults to same-origin "/api" if unset.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# ── Content moderation (optional) ─────────────────────────────────────────────
# If set, /api/media POST sends each uploaded image to this endpoint for a server-side
# verdict (expects JSON { flagged: boolean, reason?: string }); flagged uploads get 422.
# Unset = no-op pass (client nsfwjs still runs as a UX fast-fail). Fail-open on errors.
MODERATION_API_URL=""
MODERATION_API_KEY=""

# ── Observability (optional) ──────────────────────────────────────────────────
# If set, route/RPC errors are reported to Sentry. Unset = no-op.
SENTRY_DSN=""

# ── Notes ─────────────────────────────────────────────────────────────────────
# Google OAuth is configured in the Supabase dashboard (Authentication → Providers),
# NOT via env vars here.
#
# Removed in the Supabase rebuild (do not re-add):
#   MONGODB_URI, AUTH_SECRET, AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, JWT_SECRET,
#   NEXT_PUBLIC_SANITY_*, PULSE_BASE_URL, NEXT_PUBLIC_PULSE_BASE_URL, NEXT_PUBLIC_WS_BASE_URL
